{
  "name": "pathvancer-chatbot",
  "description": "Pathvancer Agentic Chatbot",
  "buildCommand": "pip install -r requirements.txt",
  "startCommand": "uvicorn app.main:app --host 0.0.0.0 --port 8000",
  "env": [
    {
      "key": "OPENAI_API_KEY",
      "scope": "run",
      "generateValue": false
    },
    {
      "key": "OPENAI_MODEL",
      "value": "gpt-3.5-turbo"
    },
    {
      "key": "DEBUG",
      "value": "false"
    },
    {
      "key": "REDIS_ENABLED",
      "value": "false"
    }
  ]
}
