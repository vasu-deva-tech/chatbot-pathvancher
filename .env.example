# ============================================
# Pathvancer Chatbot - Environment Configuration
# ============================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to Git - it contains sensitive keys

# ============================================
# REQUIRED: API Keys & Credentials
# ============================================
# Get from: https://openrouter.io/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Get from: https://app.supabase.com/project/[project-id]/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key-here

# ============================================
# OpenRouter Configuration
# ============================================
OPENROUTER_BASE_URL=https://openrouter.io/api/v1

# Available models: openai/gpt-4, openai/gpt-3.5-turbo, meta-llama/llama-2-70b, etc.
# See: https://openrouter.io/models
LLM_MODEL=openai/gpt-3.5-turbo
EMBEDDING_MODEL=openai/text-embedding-3-small

# ============================================
# Supabase Database Tables
# ============================================
# Table names where sessions and messages are stored
SUPABASE_TABLE_SESSIONS=sessions
SUPABASE_TABLE_MESSAGES=messages

# ============================================
# Session Management
# ============================================
# Session timeout in seconds (3600 = 1 hour)
SESSION_TIMEOUT=3600

# Maximum number of previous messages to keep in context
MAX_CONTEXT_HISTORY=10

# ============================================
# Application Settings
# ============================================
# Port to run the FastAPI server on
PORT=8000

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Environment: development, staging, production
ENVIRONMENT=development

# ============================================
# Optional: Advanced Settings
# ============================================
# Embedding cache size (number of embeddings to cache)
# EMBEDDING_CACHE_SIZE=1000

# Request timeout in seconds
# REQUEST_TIMEOUT=30

# Knowledge base file path
# KB_FILE_PATH=app/knowledge_base.json
